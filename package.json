{
  "name": "openqueue",
  "description": "A highly experimental library for queues working like Inngest & Trigger.dev, but using open-source BullMQ instead as the provider. Not recommended for production use at all, it's simply a proof of concept.",
  "version": "1.0.0-alpha.1",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*",
      "import": "./src/*"
    }
  },
  "types": "./src/index.ts",
  "files": [
    "src"
  ],
  "dependencies": {
    "bullmq": "^5.20.0",
    "ioredis": "^5.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@bull-board/api": "^5.21.5",
    "@bull-board/express": "^5.21.5",
    "@bull-board/ui": "^5.21.5",
    "@types/bun": "^1.1.9",
    "@types/express": "^4.17.17",
    "express": "^4.21.0",
    "tsx": "^4.19.1"
  },
  "peerDependencies": {
    "typescript": "^5.6.3"
  }
}
